{
  "name": "jobapplyassistant",
  "version": "1.0.0",
  "description": "Click-to-assist job application browser extension and companion API.",
  "main": "dist/apps/backend/src/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-extension-assets.mjs",
    "dev:backend": "tsx watch apps/backend/src/server.ts",
    "start:backend": "node dist/apps/backend/src/server.js",
    "db:migrate": "tsx apps/backend/src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "private": true
}
