{
  "name": "jobapplyassistant",
  "version": "1.0.0",
  "description": "Click-to-assist job application browser extension and companion API.",
  "main": "dist/apps/backend/src/server.js",
  "scripts": {
    "build": "npm run build:frontend && prisma generate && tsc -p tsconfig.json && node scripts/copy-extension-assets.mjs",
    "build:frontend": "vite build --config apps/frontend/vite.config.ts",
    "dev:frontend": "vite --config apps/frontend/vite.config.ts",
    "dev:backend": "tsx watch apps/backend/src/server.ts",
    "start:backend": "node dist/apps/backend/src/server.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:reset": "prisma migrate reset",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "typecheck": "tsc --noEmit && tsc -p apps/frontend/tsconfig.json --noEmit",
    "test": "npm run test:backend && npm run test:extension && npm run test:frontend",
    "test:watch": "npm run test:backend:watch && npm run test:extension:watch && npm run test:frontend:watch",
    "test:backend": "cd apps/backend && npm test",
    "test:backend:watch": "cd apps/backend && npm run test:watch",
    "test:extension": "cd apps/extension && npm test",
    "test:extension:watch": "cd apps/extension && npm run test:watch",
    "test:frontend": "cd apps/frontend && npm test",
    "test:frontend:watch": "cd apps/frontend && npm run test:watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-winston": "^4.2.0",
    "loaders.css": "^0.1.2",
    "morgan": "^1.11.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "prisma": "6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "private": true
}
