{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["./node_modules/.prisma/client/index.d.ts"]
    }
  },
  "include": ["apps/backend/**/*.ts", "apps/extension/**/*.ts"],
  "exclude": ["dist", "node_modules", "**/*.test.ts", "**/vitest.config.ts"]
}
